{
  "name": "@exodra/vite-plugin",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-syntax-jsx": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@exodra/babel-plugin-jsx": "^0.1.0",
    "@exodra/core": "^0.1.0",
    "@exodra/jsx": "^0.1.0",
    "@exodra/router": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "peerDependencies": {
    "vite": "^4.0.0 || ^5.0.0"
  },
  "description": "Vite plugin for Exodra - file-based routing, HMR, optimized builds, and Next.js-like developer experience",
  "keywords": [
    "exodra",
    "vite",
    "vite-plugin",
    "hmr",
    "hot-reload",
    "file-based-routing",
    "nextjs",
    "dev-server",
    "build-tool",
    "bundler",
    "typescript",
    "jsx"
  ],
  "author": "Andrei Baikov",
  "license": "MIT",
  "homepage": "https://exodra.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abaikov/exodra.git",
    "directory": "packages/vite-plugin-exodra"
  },
  "bugs": {
    "url": "https://github.com/abaikov/exodra/issues"
  }
}