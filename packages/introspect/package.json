{
  "name": "@exodra/introspect",
  "version": "0.1.0",
  "description": "AI-powered introspection ecosystem with universal AI tool integration and extensible plugin system for Exodra applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://exodra.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abaikov/exodra.git",
    "directory": "packages/introspect"
  },
  "bugs": {
    "url": "https://github.com/abaikov/exodra/issues"
  },
  "bin": {
    "exo-introspect": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ai": {
      "import": "./dist/ai.js",
      "types": "./dist/ai.d.ts"
    },
    "./analysis": {
      "import": "./dist/analysis.js",
      "types": "./dist/analysis.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    },
    "./router": {
      "import": "./dist/router.js",
      "types": "./dist/router.d.ts"
    },
    "./integrations/cursor": {
      "import": "./dist/integrations/cursor.js",
      "types": "./dist/integrations/cursor.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -b",
    "prepublishOnly": "npm run build",
    "cli": "node dist/cli.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@exodra/core": "^0.1.0",
    "@exodra/jsx": "^0.1.0",
    "@babel/parser": "^7.23.9",
    "@babel/traverse": "^7.23.9",
    "@babel/types": "^7.23.9",
    "typescript": "^5.3.3",
    "ts-morph": "^21.0.1",
    "glob": "^10.3.10",
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.5",
    "@types/node": "^20.11.5",
    "vitest": "^1.2.1"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "keywords": [
    "exodra",
    "introspection",
    "developer-tools",
    "static-analysis",
    "ai",
    "ai-integration", 
    "plugins",
    "code-analysis",
    "performance",
    "cursor",
    "claude",
    "openai",
    "typescript"
  ],
  "author": "Andrei Baikov",
  "license": "MIT"
}