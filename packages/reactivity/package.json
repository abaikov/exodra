{
  "name": "@exodra/reactivity",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "find src -name '*.js' -o -name '*.d.ts' -o -name '*.js.map' -o -name '*.d.ts.map' | xargs rm -f 2>/dev/null || true",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "description": "Fine-grained reactive state management for Exodra - signals, computed values, and reactive lists",
  "keywords": [
    "exodra",
    "reactivity",
    "reactive",
    "signals",
    "state-management",
    "observable",
    "computed",
    "bindable",
    "reactive-list",
    "fine-grained",
    "typescript",
    "performance"
  ],
  "author": "Andrei Baikov",
  "license": "MIT",
  "homepage": "https://exodra.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abaikov/exodra.git",
    "directory": "packages/reactivity"
  },
  "bugs": {
    "url": "https://github.com/abaikov/exodra/issues"
  },
  "devDependencies": {
    "vitest": "^1.2.1"
  },
  "dependencies": {
    "@exodra/reactivity-types": "^0.1.0"
  }
}
