{
  "name": "@exodra/reactivity-types",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "find src -name '*.js' -o -name '*.d.ts' -o -name '*.js.map' -o -name '*.d.ts.map' | xargs rm -f 2>/dev/null || true",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "description": "The reactive-value contract for Exodra (types only) — TExoBindable / TExoBindableList / TExoListOp. Renderers and reactivity implementations depend on this, not on each other.",
  "keywords": [
    "exodra",
    "reactivity",
    "types",
    "contract",
    "bindable",
    "typescript"
  ],
  "author": "Andrei Baikov",
  "license": "MIT",
  "homepage": "https://exodra.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abaikov/exodra.git",
    "directory": "packages/reactivity-types"
  },
  "bugs": {
    "url": "https://github.com/abaikov/exodra/issues"
  }
}
