{
  "name": "@exodra/dom",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@exodra/core": "^0.1.0",
    "@exodra/reactivity": "^0.1.0"
  },
  "scripts": {
    "prebuild": "find src -name '*.js' -o -name '*.d.ts' -o -name '*.js.map' -o -name '*.d.ts.map' | xargs rm -f 2>/dev/null || true",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "description": "High-performance DOM renderer for Exodra - mount, hydrate, and update with WeakMap-based tracking",
  "keywords": [
    "exodra",
    "dom",
    "renderer",
    "mount",
    "hydration",
    "ssr",
    "browser",
    "weakmap",
    "performance",
    "reactive-dom",
    "fine-grained",
    "typescript"
  ],
  "author": "Andrei Baikov",
  "license": "MIT",
  "homepage": "https://exodra.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abaikov/exodra.git",
    "directory": "packages/dom"
  },
  "bugs": {
    "url": "https://github.com/abaikov/exodra/issues"
  },
  "devDependencies": {
    "vitest": "^1.2.1",
    "jsdom": "^23.0.1"
  }
}
