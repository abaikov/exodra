{
  "name": "create-exodra",
  "version": "0.1.0",
  "description": "Create Exodra apps with zero configuration - Next.js-like experience",
  "bin": {
    "create-exodra": "./dist/index.js",
    "exodra": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "prompts": "^2.4.2",
    "validate-npm-package-name": "^5.0.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "@types/validate-npm-package-name": "^4.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "keywords": [
    "exodra",
    "create-exodra",
    "create-app",
    "scaffold",
    "generator",
    "starter",
    "boilerplate",
    "template",
    "nextjs",
    "file-based-routing",
    "zero-config",
    "typescript",
    "cli",
    "react-alternative"
  ],
  "author": "Andrei Baikov",
  "license": "MIT",
  "homepage": "https://exodra.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abaikov/exodra.git",
    "directory": "packages/create-exodra"
  },
  "bugs": {
    "url": "https://github.com/abaikov/exodra/issues"
  }
