{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@exodra/core": ["../core/dist/index.d.ts"],
      "@exodra/reactivity": ["../reactivity/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "**/*.test.ts", "**/*.spec.ts"],
  "references": [
    { "path": "../core" },
    { "path": "../reactivity" }
  ]
}
